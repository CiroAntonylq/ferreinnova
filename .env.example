# Copia este archivo a .env para desarrollo local.
# En Render, configura las mismas variables en el dashboard del servicio.

# Supabase — cliente (VITE_* se embeben en el build)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# Supabase — servidor SSR
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
SUPABASE_PROJECT_ID=your_project_id

# Opcional: operaciones admin en servidor
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
